PROJECT_NAME           = "OptiFlow"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
OUTPUT_DIRECTORY       = "@CMAKE_CURRENT_BINARY_DIR@/docs"
INPUT                  = "@CMAKE_CURRENT_SOURCE_DIR@/libs/optimization/include"
RECURSIVE              = YES
EXTRACT_ALL            = NO
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_AS_ERROR          = NO
JAVADOC_AUTOBRIEF      = YES
FULL_PATH_NAMES        = NO
