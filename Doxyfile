PROJECT_NAME           = "OptiFlow"
PROJECT_BRIEF          = "Pumped-storage hydro dispatch optimization demo"
OUTPUT_DIRECTORY       = docs
INPUT                  = README.md \
                         docs/model.md \
                         libs/optimization/include \
                         frontend/README.md \
                         frontend/app.js \
                         frontend/scenario.mjs \
                         frontend/number_format.mjs \
                         frontend/trader.mjs \
                         frontend/dispatch_charts.mjs \
                         backend/README.md \
                         backend/app
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.hpp *.md *.js *.mjs *.py
EXTENSION_MAPPING      = js=JavaScript mjs=JavaScript
EXCLUDE_PATTERNS       = */*.test.mjs */tests/* */__pycache__/*
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
QUIET                  = YES
JAVADOC_AUTOBRIEF      = YES
PYTHON_DOCSTRING       = NO
WARN_IF_UNDOCUMENTED   = YES
WARN_AS_ERROR          = NO
HAVE_DOT               = NO
