PROJECT_NAME           = "OptiFlow"
PROJECT_NUMBER         = @PROJECT_VERSION@
PROJECT_BRIEF          = "C++20 pumped-storage and battery dispatch optimizer"
OUTPUT_DIRECTORY       = @OPTIFLOW_DOXYGEN_OUTPUT_DIR@
INPUT                  = @CMAKE_CURRENT_SOURCE_DIR@/README.md \
                         @CMAKE_CURRENT_SOURCE_DIR@/docs \
                         @CMAKE_CURRENT_SOURCE_DIR@/libs/optimization/include \
                         @CMAKE_CURRENT_SOURCE_DIR@/libs/demo/include \
                         @CMAKE_CURRENT_SOURCE_DIR@/libs/service_common/include
USE_MDFILE_AS_MAINPAGE = @CMAKE_CURRENT_SOURCE_DIR@/README.md
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.md
EXCLUDE_PATTERNS       = */build/*

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = YES

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES

WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = NO
QUIET                  = NO

HAVE_DOT               = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
CLASS_DIAGRAMS         = YES
